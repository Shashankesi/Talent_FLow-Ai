# Render Deployment Environment Variables Template

# ============================================
# MONGODB CONFIGURATION
# ============================================
# Get this from MongoDB Atlas: Cluster → Connect → Connection String
MONGODB_URI=mongodb+srv://REDACTED@REDACTED_CLUSTER.mrrc1c2.mongodb.net/talentflow?retryWrites=true&w=majority&authSource=admin

# ============================================
# JWT SECURITY
# ============================================
# Change this to a strong random string (minimum 32 characters)
JWT_SECRET=REDACTED_JWT_SECRET-production-minimum-32-characters-required-for-hs256

# ============================================
# CORS CONFIGURATION
# ============================================
# Add your frontend URL here (important for security)
# Format: https://your-frontend.onrender.com,http://localhost:3000
CORS_ORIGINS=https://talentflow-frontend.onrender.com,http://localhost:3000,http://localhost:3001

# ============================================
# API CONFIGURATION (FRONTEND)
# ============================================
# This is used in the frontend build process
# Set to your deployed backend URL
REACT_APP_API_BASE_URL=https://talentflow-backend.onrender.com/api

# ============================================
# PORT CONFIGURATION
# ============================================
# Render automatically sets PORT environment variable
# Your app.properties already handles this: server.port=${PORT:8081}
# No need to set it manually
PORT=8081

# ============================================
# NODE ENVIRONMENT
# ============================================
# Used by Vite to determine build mode
NODE_ENV=production
