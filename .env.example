# TalentFlow AI - Environment Variables Template
# ============================================
# This file shows all required environment variables
# Copy sections to your actual .env files (backend/.env and frontend/.env)
# NEVER commit .env files to git (they're in .gitignore)
# ============================================

# ========================================
# BACKEND CONFIGURATION (.env in backend/)
# ========================================

# Server port (on Render, this is auto-set via PORT env var)
PORT=8080

# MongoDB Atlas connection string (REQUIRED)
# Get from: MongoDB Atlas → Cluster → Connect → Connection String
SPRING_DATA_MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/talentflow?retryWrites=true&w=majority&authSource=admin

# JWT secret for token generation (REQUIRED)
# Generate: openssl rand -base64 32
JWT_SECRET=your-min-32-character-secret-key-here

# CORS allowed origins (REQUIRED)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# FRONTEND CONFIGURATION (.env in frontend/)
# ========================================

# Backend API URL
VITE_API_BASE_URL=http://localhost:8081/api

# ========================================
# RENDER DEPLOYMENT
# ========================================
# Set these in Render Dashboard (NOT in git):
# 
# Backend Service Environment Variables:
#   - SPRING_DATA_MONGODB_URI: mongodb+srv://...
#   - JWT_SECRET: your-secret-key
#   - CORS_ORIGINS: https://talentflow-frontend.onrender.com
#
# Frontend Service Environment Variables:
#   - REACT_APP_API_BASE_URL: https://talentflow-backend.onrender.com/api
