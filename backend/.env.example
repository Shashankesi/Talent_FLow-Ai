# Backend Environment Variables
# Copy this file to .env and update with your values

# MongoDB Configuration
MONGODB_URI=mongodb+srv://REDACTED@REDACTED_CLUSTER.mrrc1c2.mongodb.net/?appName=TalentFlowCluster

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# JWT Configuration
JWT_SECRET=talentflow-super-secure-secret-key-2024-minimum-64-characters-for-hs512-algorithm-required
JWT_EXPIRATION=86400000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true

# File Upload
MAX_FILE_SIZE=10485760
MAX_REQUEST_SIZE=10485760

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_TALENTFLOW=DEBUG

# Email Configuration (Optional)
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@talentflow-ai.com

# AWS S3 (Optional - for file storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=talentflow-resumes
AWS_REGION=us-east-1
