# TalentFlow AI - Backend Environment Variables
# ============================================
# SECURITY WARNING:
# 1. Copy this file to .env (not .env.example)
# 2. Fill in your ACTUAL values
# 3. NEVER commit .env to git
# 4. Add .env to .gitignore (already done)
# ============================================

# SERVER CONFIGURATION
# Default: 8080 (on Render, PORT is auto-set)
PORT=8080

# MONGODB ATLAS CONNECTION (REQUIRED)
# Get from: MongoDB Atlas → Your Cluster → Connect → Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&authSource=admin
SPRING_DATA_MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/talentflow?retryWrites=true&w=majority&authSource=admin

# JWT SECRET (REQUIRED)
# Generate: openssl rand -base64 32
# Minimum 32 characters for HS256 algorithm
JWT_SECRET=your-min-32-character-secret-key-here-replace-with-real-value

# CORS ORIGINS (REQUIRED for production)
# Local: http://localhost:3000,http://localhost:5173
# Production: https://your-frontend.onrender.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LOGGING LEVELS (Optional)
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_TALENTFLOW=INFO

